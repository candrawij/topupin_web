# ============================================================
# TopUpin Bot Telegram - Environment Variables Template
# Salin file ini menjadi .env dan isi nilainya
# ============================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# --- Website ---
WEBSITE_BASE_URL=https://topupinweb.my.id

# --- Admin & CS ---
ADMIN_GROUP_CHAT_ID=0
CS_OFFLINE=false

# --- Hermes AI Agent (opsional) ---
HERMES_AGENT_URL=http://localhost:3000
HERMES_AGENT_API_KEY=your_hermes_api_key_here
HERMES_AGENT_MODEL=gpt-4o-mini

# --- Mode Webhook (Production) ---
WEBSITE_API_PORT=3001
WEBHOOK_DOMAIN=https://topupinweb.my.id
WEBHOOK_PATH=/telegram-webhook
WEBHOOK_SECRET_TOKEN=your_secure_random_token_here

# --- Database ---
DATABASE_URL="mysql://DB_USER:DB_PASS@localhost:3306/topup_game"

# --- Deep Link (harus sama persis dengan config/telegram_helper.php) ---
DEEP_LINK_SECRET=your_32_character_secret_key_here
